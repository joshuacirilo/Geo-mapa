generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma-main"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Marker {
  id        Int    @id @default(autoincrement())
  id_public String @unique
  title     String
  categoria String
  geojson   Json
}
