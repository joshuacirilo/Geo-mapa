generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma-analytics"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL_ANALYTICS")
}

model AnalyticsEvent {
  id        Int      @id @default(autoincrement())
  eventType String
  payload   Json?
  createdAt DateTime @default(now())
}
